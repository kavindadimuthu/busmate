{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "noFallthroughCasesInSwitch": false,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@busmate/api-client-route": ["../../../libs/api-clients/route-management/src/index.ts"],
      "@busmate/api-client-ticketing": ["../../../libs/api-clients/ticketing-management/src/index.ts"],
      "@busmate/api-client-location": ["../../../libs/api-clients/location-tracking/src/index.ts"],
      "@busmate/api-client-user": ["../../../libs/api-clients/user-management/src/index.ts"]
    }
  },
  "include": ["src"]
}
