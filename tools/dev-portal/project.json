{
  "name": "dev-portal",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "root": "tools/dev-portal",
  "sourceRoot": "tools/dev-portal/src",
  "tags": ["scope:tools", "type:app", "framework:vite", "lang:typescript"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "vite",
          "tsx watch server/index.ts"
        ],
        "parallel": true,
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite build",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/dist"],
      "inputs": ["production", "^production"],
      "cache": true
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite preview",
        "cwd": "{projectRoot}"
      }
    },
    "build:server": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.server.json",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["build"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node server/dist/index.js",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["build", "build:server"]
    }
  }
}
