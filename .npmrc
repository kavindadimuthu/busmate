# ──────────────────────────────────────────────────────────────
# pnpm workspace configuration for BusMate monorepo
# ──────────────────────────────────────────────────────────────

# Use hoisted linker: all packages land in a single root node_modules,
# preventing any app-level node_modules directories from being created.
node-linker=hoisted

# Always resolve workspace packages from source rather than the registry.
link-workspace-packages=true

# Keep a single pnpm-lock.yaml at the workspace root (default, explicit here).
shared-workspace-lockfile=true

# Prevent spurious lockfile mutations during installs triggered by Nx.
frozen-lockfile=false

# Do not autogenerate a shrinkwrap in addition to the lockfile.
save-lockfile=true

# Hoist only peer dependencies of packages (no random hoisting).
# With node-linker=hoisted this is effectively a no-op, but kept for clarity.
hoist=true

# Save exact versions by default (good for monorepo reproducibility).
save-exact=false
