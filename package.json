{
  "name": "busmate",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "dev:management-portal": "nx dev management-portal",
    "dev:passenger-web": "nx dev passenger-web",
    "build": "nx run-many -t build",
    "build:management-portal": "nx build management-portal",
    "build:passenger-web": "nx build passenger-web",
    "build:api-core": "nx build api-core",
    "serve:api-core": "nx serve api-core",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "graph": "nx graph",
    "nx": "nx",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report tests/e2e/playwright-report",
    "e2e:docker": "bash tests/e2e/scripts/check-e2e-env.sh && E2E_DOCKER=true playwright test",
    "e2e:docker:headed": "bash tests/e2e/scripts/check-e2e-env.sh && E2E_DOCKER=true HEADED=true playwright test --headed",
    "e2e:docker:slow": "bash tests/e2e/scripts/check-e2e-env.sh && E2E_DOCKER=true HEADED=true SLOW_MO=500 playwright test --headed",
    "e2e:docker:debug": "bash tests/e2e/scripts/check-e2e-env.sh && E2E_DOCKER=true playwright test --debug",
    "e2e:docker:ui": "bash tests/e2e/scripts/check-e2e-env.sh && E2E_DOCKER=true playwright test --ui",
    "e2e:env:start": "bash tests/e2e/scripts/e2e-env.sh start",
    "e2e:env:stop": "bash tests/e2e/scripts/e2e-env.sh stop",
    "e2e:env:status": "bash tests/e2e/scripts/e2e-env.sh status",
    "e2e:env:logs": "bash tests/e2e/scripts/e2e-env.sh logs",
    "e2e:env:check": "bash tests/e2e/scripts/check-e2e-env.sh"
  },
  "devDependencies": {
    "nx": "^21.0.0",
    "shadcn": "^4.0.2"
  },
  "pnpm": {
    "overrides": {}
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  }
}
