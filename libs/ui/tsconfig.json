{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@busmate/ui": ["./src/index.ts"],
      "@busmate/ui/*": ["./src/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.mdx", ".storybook/**/*.ts", ".storybook/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
