# E2E Test Environment — Configuration
# ======================================
# Copy this file to .env and fill in your values before running tests.
#
#   cp .env.example .env
#
# Two workflows are supported:
#
# 1. Docker e2e environment (recommended — fully isolated)
#    -------------------------------------------------------
#    Uses dedicated Docker containers for PostgreSQL and the Spring Boot
#    backend that are completely separate from your development environment.
#
#    a. Start the isolated environment:
#         pnpm run e2e:env:start
#
#    b. Run tests against it:
#         pnpm run e2e:docker
#
#    c. Stop and clean up when done:
#         pnpm run e2e:env:stop
#
#    Use the values in the "Docker e2e environment" section below.
#
# 2. Local development environment
#    --------------------------------
#    Tests run against your locally running dev backend and database.
#    This is NOT recommended for regular test runs as it contaminates
#    your dev database with test data.
#
#    Use the values in the "Local development environment" section below.

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Next.js management portal — started automatically by Playwright's webServer.
BASE_URL=http://localhost:3000

# ── Backend API URL ───────────────────────────────────────────────────────────
# Docker e2e environment  →  http://localhost:8081  (separate port, isolated)
# Local development       →  http://localhost:8080  (shared dev backend)
API_URL=http://localhost:8081

# ── Asgardeo test credentials ─────────────────────────────────────────────────
# Must be a real Asgardeo user with the MOT role assigned.
# Do NOT use personal or production credentials here.
ASGARDEO_TEST_USERNAME=mot-test-user@busmate.lk
ASGARDEO_TEST_PASSWORD=SecureTestPassword123!

# ── Test Execution Modes ──────────────────────────────────────────────────────
# Configure browser visibility and execution speed for debugging.

# HEADED mode — show browser UI during test execution
# - false (default): headless mode — invisible, fast, ideal for CI and performance
# - true: headed mode — visible browser window, ideal for debugging and watching tests
# 
# Quick usage:
#   pnpm run e2e:docker          → headless (CI mode)
#   pnpm run e2e:docker:headed   → headed mode
#   pnpm run e2e:docker:slow     → headed + slowed down for clarity
HEADED=false

# SLOW_MO — slow down test operations by N milliseconds
# Controls the delay between Playwright actions to make tests easier to follow visually.
# - 0 (default): full speed
# - 300-500: comfortable viewing speed, not too fast or slow
# - 800-1000: slower pace, easier to see each action clearly
# - 1500+: very slow, use for detailed step-by-step debugging
#
# Quick usage:
#   SLOW_MO=500 pnpm run e2e:docker:headed
#   pnpm run e2e:docker:slow  (uses SLOW_MO=500 by default)
SLOW_MO=0
