{
  "$schema": "./node_modules/nx/schemas/tsconfig.schema.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "dom", "dom.iterable"],
    "strict": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "noEmit": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@busmate/management-portal/*": ["apps/frontend/management-portal/src/*"],
      "@busmate/passenger-web/*": ["apps/frontend/passenger-web/src/*"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist", ".next", "out"]
}
