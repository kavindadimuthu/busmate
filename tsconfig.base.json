{
  "$schema": "./node_modules/nx/schemas/tsconfig.schema.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "dom", "dom.iterable"],
    "strict": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "noEmit": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@busmate/ui": ["libs/ui/src/index.ts"],
      "@busmate/ui/*": ["libs/ui/src/*"],
      "@busmate/api-client-route": ["libs/api-clients/route-management/src/index.ts"],
      "@busmate/api-client-ticketing": ["libs/api-clients/ticketing-management/src/index.ts"],
      "@busmate/api-client-location": ["libs/api-clients/location-tracking/src/index.ts"],
      "@busmate/api-client-user": ["libs/api-clients/user-management/src/index.ts"],
      "@busmate/management-portal/*": ["apps/frontend/management-portal/src/*"],
      "@busmate/passenger-web/*": ["apps/frontend/passenger-web/src/*"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist", ".next", "out"]
}
